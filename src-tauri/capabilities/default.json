{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Filesystem + dialog access for scenario JSON storage",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "os:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/SailingTactics" },
        { "path": "$HOME/SailingTactics/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" }
      ]
    }
  ]
}
