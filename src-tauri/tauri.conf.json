{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sailing Tactics",
  "version": "0.1.0",
  "identifier": "com.sailingtactics.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sailing Tactics",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "iOS": {
      "developmentTeam": "FPST3M7C92",
      "minimumSystemVersion": "13.0"
    }
  }
}
